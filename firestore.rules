rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isRideParticipant(rideData) {
      return isSignedIn() && (request.auth.uid == rideData.passengerId || request.auth.uid == rideData.driverId);
    }

    // --- Collection Rules ---

    /**
     * Users collection: Profiles for all users.
     */
    match /users/{userId} {
      allow get, list, create, update, delete: if isOwner(userId);
    }

    /**
     * Drivers collection: Operational data for drivers.
     * Passengers need to read this to see available drivers.
     */
    match /drivers/{driverId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isOwner(driverId);
    }

    /**
     * Rides collection: Transactional data between passengers and drivers.
     */
    match /rides/{rideId} {
      allow get: if isRideParticipant(resource.data);
      allow list: if isSignedIn(); 
      allow create: if isSignedIn() && request.resource.data.passengerId == request.auth.uid;
      allow update: if isRideParticipant(resource.data);
      allow delete: if false;
    }

  }
}