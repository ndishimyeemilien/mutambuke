{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user account in the MUTAMBUKE system, abstracting common details for both passengers and drivers.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "fullName": {
          "type": "string",
          "description": "The full name of the user."
        },
        "phoneNumber": {
          "type": "string",
          "description": "The user's contact phone number."
        },
        "nationalId": {
          "type": "string",
          "description": "The user's national identification number."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The role of the user ('passenger', 'driver', 'admin')."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of account creation.",
          "format": "date-time"
        },
        "profilePictureUrl": {
          "type": "string",
          "description": "URL to the user's profile picture.",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "fullName",
        "phoneNumber",
        "role",
        "createdAt"
      ]
    },
    "DriverProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "DriverProfile",
      "type": "object",
      "description": "Stores detailed information specific to a driver.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the DriverProfile."
        },
        "userId": {
          "type": "string",
          "description": "Reference to the associated UserProfile."
        },
        "status": {
          "type": "string",
          "description": "Availability status ('online', 'offline', 'busy')."
        },
        "verificationStatus": {
          "type": "string",
          "description": "Verification status ('pending', 'approved', 'rejected')."
        },
        "currentLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "drivingLicenseNumber": {
          "type": "string",
          "description": "The driver's license number."
        },
        "licenseCategory": {
          "type": "string",
          "description": "Category of the driving license."
        },
        "motoPlateNumber": {
          "type": "string",
          "description": "License plate number."
        },
        "motoBrandModel": {
          "type": "string",
          "description": "Brand and model of the moto."
        },
        "motoInsuranceNumber": {
          "type": "string",
          "description": "Insurance policy number."
        },
        "cooperativeName": {
          "type": "string",
          "description": "Name of the driver cooperative."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "status",
        "verificationStatus",
        "drivingLicenseNumber",
        "motoPlateNumber"
      ]
    },
    "Ride": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Ride",
      "type": "object",
      "description": "Records details of a ride transaction.",
      "properties": {
        "id": { "type": "string" },
        "passengerId": { "type": "string" },
        "driverId": { "type": "string" },
        "pickupLocation": { "type": "object" },
        "destination": { "type": "string" },
        "status": { "type": "string" },
        "vehicleType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Core user profiles."
        }
      },
      {
        "path": "/drivers/{driverId}",
        "definition": {
          "entityName": "DriverProfile",
          "schema": { "$ref": "#/backend/entities/DriverProfile" },
          "description": "Driver-specific data."
        }
      },
      {
        "path": "/rides/{rideId}",
        "definition": {
          "entityName": "Ride",
          "schema": { "$ref": "#/backend/entities/Ride" },
          "description": "Ride requests and history."
        }
      }
    ]
  }
}